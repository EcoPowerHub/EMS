{
  "debug": true,
  "context": {
    "objects": {
      "pv1": {
        "type": "pv",
        "description": "Ouai les gars c'est le pv, ça photovoltaïque un max ou quoi ? 🤙"
      },
      "poc": {
        "type": "metric",
        "description": "Ouai les gars c'est le poc, ça mesure un max ou quoi ? 🤙",
        "init_value": {
          "value": 1000
        }
      },
      "limit": {
        "type": "metric",
        "description": "Ouai les gars c'est le limit, ça limite un max ou quoi ? 🤙",
        "init_value": {
          "value": 100
        }
      },
      "setpoint": {
        "type": "setpoint",
        "description": "Ouai les gars c'est le setpoint, ça setpoint un max ou quoi ? 🤙",
        "init_value": {
          "p_kw": 0
        }
      },
      "load":{
        "type": "metric",
        "description": "Ouai les gars c'est le load, ça consomme un max ou quoi ? 🤙"
      },
      "ess":{
        "type": "battery",
        "description": "Ouai les gars c'est l'ess, ça stocke un max ou quoi ? 🤙"
      },
      "battery_status":{
        "type": "status",
        "description": "Ouai les gars c'est le status, ça status un max ou quoi ? 🤙",
        "init_value": {
          "value": 1
        }
      }
    }
  },
  "equipments": [
    {
      "id": "generic/battery",
      "description": "equipmentBatterie",
      "host": "localhost:5502",
      "name": "battery",
      "inputs": {
        "setpoint": {
          "setpoint":{
            "ref": "setpoint"
          }
        }
      },
      "outputs": {
        "battery": {
          "battery": {
            "ref": "ess"
          }
        }
      }
    }
  ],

  "modes": {
    "modes":[
      {
        "name":"peakshaving",
        "description":"Ouai les gars c'est le peakshaving, ça shave un max ou quoi ? 🤙",
        "enabledServices":["peakshaving", "eval"],
        "condition":"default"
      }
    ]
  },

  "services": {
    "peakshaving": {
      "id": "peakshaving",
      "priority": 1,
      "conf": {
        "conf": {
          "pid_controller": {
            "kp": 0.1,
            "ki": 0.1,
            "kd": 0.1,
            "period": "1s"
          }
        },
        "inputs": {
          "poc_kW": {
            "ref": "poc",
            "attr": "value"
          },
          "limit_kW": {
            "ref": "limit",
            "attr": "value"
          }
        },
        "outputs": {
          "setpoint": {
            "ref": "setpoint"
          }
        }
      }
    },
    "eval":{
      "id": "gval",
      "priority": 2,
      "conf": {
        "conf": {
          "expression": "setpoint * -0.001"
        },
        "inputs": {
          "setpoint": {
            "ref": "setpoint",
            "attr": "p_kw"
          }
        },
        "outputs": {
          "osetpoint": {
            "ref": "setpoint",
            "attr": "p_kw"
          }
        }
      }
    }
  }
}
